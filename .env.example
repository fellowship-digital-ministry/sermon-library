OPENAI_API_KEY=
OPENROUTER_API_KEY=
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=sermon-embeddings

# Retrieval calibration (optional — defaults shown).
# ANSWER_SCORE_FLOOR: min similarity for a segment to reach the answer model.
#   Lower it if on-topic questions get "I couldn't find sermon content"; the
#   grounded prompt still refuses to answer from irrelevant context.
# SOURCE_SCORE_FLOOR: min similarity for a segment to show in the sources panel.
#   Keep it above the answer floor so weak matches don't masquerade as citations.
ANSWER_SCORE_FLOOR=0.38
SOURCE_SCORE_FLOOR=0.55
